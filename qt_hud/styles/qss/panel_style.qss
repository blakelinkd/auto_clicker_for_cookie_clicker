QGroupBox {
            font-weight: bold;
            border: 1px solid %border_color%;
            border-radius: 8px;
            margin-top: 10px;
            padding-top: 10px;
            color: %accent_green%;
        }
        QGroupBox::title {
            subcontrol-origin: margin;
            left: 10px;
            padding: 0 5px 0 5px;
        }